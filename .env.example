# Hermes Super Memory — Environment Variables Example
# Copy this file to .env and fill in your values.

# === Ollama (Local LLM) ===
# URL for local Ollama instance
OLLAMA_URL=http://localhost:11434/api/chat

# Model used for session summarization
HERMES_SUMMARIZER_MODEL=qwen2.5:7b

# Model used for fact extraction (optional, defaults to summarizer model)
HERMES_EXTRACTOR_MODEL=qwen2.5:7b

# === Memory Configuration ===
# Minimum idle time (minutes) before a session is summarized
HERMES_SESSION_IDLE_MINUTES=30

# === Graph Configuration ===
# Enable Mem0-style decision loop (optional, 0=disabled, 1=enabled)
MEM0_DECISION=0

# === Paths ===
# Base directory for Hermes data (default: ~/.hermes)
# HERMES_HOME=~/.hermes

# === Optional: External Embedding API ===
# If not using local BGE-M3, configure an external embedding provider
# EMBEDDING_API_URL=
# EMBEDDING_API_KEY=
